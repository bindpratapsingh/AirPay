<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.offlineupi.app.fragments.HomeFragment"
        android:label="Home">
        <action
            android:id="@+id/action_home_to_pay"
            app:destination="@id/payFragment" />
    </fragment>

    <fragment
        android:id="@+id/payFragment"
        android:name="com.offlineupi.app.fragments.PayFragment"
        android:label="Pay">
        <argument
            android:name="prefill_identifier"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="prefill_name"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="prefill_is_upi"
            app:argType="boolean"
            android:defaultValue="false" />
    </fragment>

    <fragment
        android:id="@+id/historyFragment"
        android:name="com.offlineupi.app.fragments.HistoryFragment"
        android:label="History" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.offlineupi.app.fragments.SettingsFragment"
        android:label="Settings" />

</navigation>
